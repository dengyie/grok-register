# Grok 注册机 - 环境变量模板
# 复制为 .env 并填入真实值（.env 已 gitignore）
# 真实进程环境变量优先于 .env；.env 又覆盖 config.json 中同名开关（见 apply_env_config_overrides）

# --- Hotmail / Outlook 邮箱池 ---
# 不要把 refresh_token / 密码写进 .env！
# 凭证文件格式见 mail_credentials.example.txt：
#   email----password----ClientID----Token
EMAIL_PROVIDER=hotmail
HOTMAIL_ACCOUNTS_FILE=mail_credentials.txt
# 批量资产目录（本地）：mail_assets/hotmail.com_*.txt → 合并进 mail_credentials.txt

# --- 代理 ---
PROXY=http://127.0.0.1:7890
CPA_PROXY=http://127.0.0.1:7890

# --- 代理/出口 IP 轮换（注册级，不动整机出口）---
# off=list 不动；list=轮换 PROXY_LIST（仅注册浏览器/HTTP）
# clash=在 Clash 专用策略组 GROK-REG 上轮换（DOMAIN-SUFFIX 命中 x.ai/grok.com 才走该组，主策略组不动）
PROXY_ROTATE_MODE=off
PROXY_ROTATE_EVERY=1
# list 模式：逗号/分号/换行分隔，或 .txt/.list 文件路径
PROXY_LIST=
# clash 模式：unix socket 或 http://host:port
CLASH_API=unix:///tmp/verge/verge-mihomo.sock
CLASH_PROXY_GROUP=GROK-REG
CLASH_DONOR_GROUP=宝可梦
CLASH_RULE_DOMAINS=x.ai,grok.com,grok.x.ai,assets.grok.com
# 进程结束自动恢复专用组原节点（绝不碰主组）
CLASH_RESTORE_ON_EXIT=true

# --- 一键 CPA 远端注入 ---
CPA_REMOTE_INJECT=false
CPA_REMOTE_LIVE_REQUIRED=true
CPA_REMOTE_INJECT_REQUIRED=false
CPA_REMOTE_SSH_HOST=tebi-tunnel
CPA_REMOTE_SSH_USER=
CPA_REMOTE_LIVE_DIR=/root/.cli-proxy-api
CPA_REMOTE_AUTH_DIRS=/root/.cli-proxy-api,/personal/cpa/auths
CPA_REMOTE_AUTH_DIR=/personal/cpa/auths
CPA_REMOTE_CREDENTIALS_FILE=~/.ssh/bohrium_credentials
CPA_REMOTE_CREDENTIAL_ALIAS=tebi
# 也可用环境变量注入 SSH 密码（勿提交）：
# CPA_REMOTE_SSHPASS=
# SSHPASS=
CPA_AUTH_DIR=./cpa_auths
CPA_AUTH_PRIORITY=1000
CPA_EXPORT_ENABLED=true
CPA_PROTOCOL_ONLY=false
# free Build product gate: models-only is not enough (chat 403 = no entitlement)
CPA_PROBE_CHAT=true
CPA_PROBE_CHAT_REQUIRED=true

# --- CloudMail（email_provider=cloudmail 时）---
CLOUDMAIL_URL=
CLOUDMAIL_ADMIN_EMAIL=
CLOUDMAIL_PASSWORD=

# --- Gmail app-password IMAP（email_provider=gmail；CF 域名 catch-all → Gmail）---
# 应用专用密码，不是登录密码；勿提交真实值
# EMAIL_PROVIDER=gmail
# GMAIL_IMAP_USER=you@gmail.com
# GMAIL_IMAP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_IMAP_HOST=imap.gmail.com
# GMAIL_IMAP_PORT=993
# GMAIL_IMAP_FOLDER=INBOX
# DEFAULT_DOMAINS=your-cf-domain.com

# --- grok2api ---
GROK2API_APP_KEY=
GROK2API_REMOTE_BASE=http://127.0.0.1:8000/admin/api

# --- 测试 ---
# GROK_REGISTER_LIVE=1
