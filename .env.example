# Grok 注册机 - 环境变量模板
# 复制为 .env 并填入真实值（.env 已 gitignore）
# 真实进程环境变量优先于 .env；.env 又覆盖 config.json 中同名开关（见 apply_env_config_overrides）

# --- Hotmail / Outlook 邮箱池 ---
# 不要把 refresh_token / 密码写进 .env！
# 凭证文件格式见 mail_credentials.example.txt：
#   email----password----ClientID----Token
# 单选（兼容）：只启用一条邮箱链路
EMAIL_PROVIDER=hotmail
# 多选（优先于 EMAIL_PROVIDER）：逗号/空格分隔，注册时按策略轮用全部已选链路
# 合法名：duckmail,yyds,cloudflare,cloudmail,hotmail,gmail
# （tinyhost 走 register_core profile，不在 legacy EMAIL_PROVIDERS 池内）
# EMAIL_PROVIDERS=duckmail,gmail,cloudflare
# 策略：round_robin（默认，每 attempt 轮询）| random | failover（失败才切下一家）
# EMAIL_PROVIDER_STRATEGY=round_robin
# DuckMail（第三方临邮 api.duckmail.sbs，非域名邮箱）
# 公开接口可无 key 创建；有 key 时写 DUCKMAIL_API_KEY（env 优先于 config.json）
# DUCKMAIL_API_KEY=
HOTMAIL_ACCOUNTS_FILE=mail_credentials.txt
# 批量资产目录（本地）：mail_assets/hotmail.com_*.txt → 合并进 mail_credentials.txt

# --- 代理 ---
PROXY=http://127.0.0.1:7890
CPA_PROXY=http://127.0.0.1:7890

# --- 注册节点池 soft cooldown（与 hard quarantine 分离）---
# risk=registration_disallowed 软冷却（不 quarantine）；network 仍计 fail_count
# PER_USE 默认 0=关闭，避免小池饿死
# REGISTER_NODES_COOLDOWN_RISK=600
# REGISTER_NODES_COOLDOWN_NETWORK=120
# REGISTER_NODES_COOLDOWN_PER_USE=0
# REGISTER_NODES_MAX_FAIL=3
# REGISTER_NODES_SKIP_FAILED=1
# mail_miss / captcha / verify / fatal 永不 cool/quarantine 节点

# --- 邮件路径独立代理（ChatGPT / tinyhost HTTP 等）---
# 默认直连；禁止把注册 PROXY_LIST 静默塞进邮件路径
# CHATGPT_MAIL_PROXY=
# EMAIL_PROXY=
# MAIL_PROXY=

# --- 代理/出口 IP 轮换（注册级，不动整机出口）---
# 多账号冷 IP：优先 PROXY_ROTATE_MODE=list + PROXY_LIST（自控节点池）
# 单节点烟测/固定出口：clash + GROK_NODE/CLASH_PIN_NODE 钉住（on_start 不 advance）
# clash=仅专用组 GROK-REG 轮换（DOMAIN-SUFFIX 命中 x.ai/grok.com；主策略组不动）
PROXY_ROTATE_MODE=off
PROXY_ROTATE_EVERY=1
# 节点双池策略（nodes.json tier：0=机房/普通，1=加宽/家宽/住宅）
# residential|加宽|家宽 = 只用 tier>=1
# datacenter|机房|普通|非加宽 = 只用 tier==0
# both|混用 = 两池都用（默认）
# REGISTER_NODES_POOL=both
# list 模式：逗号/分号/换行分隔，或 .txt/.list 文件路径
PROXY_LIST=
# clash 模式：unix socket 或 http://host:port
CLASH_API=unix:///tmp/verge/verge-mihomo.sock
CLASH_PROXY_GROUP=GROK-REG
CLASH_DONOR_GROUP=宝可梦
CLASH_RULE_DOMAINS=x.ai,grok.com,grok.x.ai,assets.grok.com
# 钉死 clash 节点名（与 config clash_pin_node 等价；start-clash-for-grok.sh 也读 GROK_NODE）
# GROK_NODE=GVPS-TUIC-googlevps
# CLASH_PIN_NODE=
# 进程结束自动恢复专用组原节点（绝不碰主组）
CLASH_RESTORE_ON_EXIT=true

# --- 一键 CPA 远端注入 ---
CPA_REMOTE_INJECT=false
CPA_REMOTE_LIVE_REQUIRED=true
CPA_REMOTE_INJECT_REQUIRED=false
CPA_REMOTE_SSH_HOST=tebi-tunnel
CPA_REMOTE_SSH_USER=
CPA_REMOTE_LIVE_DIR=/root/.cli-proxy-api
CPA_REMOTE_AUTH_DIRS=/root/.cli-proxy-api,/personal/cpa/auths
CPA_REMOTE_AUTH_DIR=/personal/cpa/auths
CPA_REMOTE_CREDENTIALS_FILE=~/.ssh/bohrium_credentials
CPA_REMOTE_CREDENTIAL_ALIAS=tebi
# 也可用环境变量注入 SSH 密码（勿提交）：
# CPA_REMOTE_SSHPASS=
# SSHPASS=
CPA_AUTH_DIR=./cpa_auths
CPA_AUTH_PRIORITY=1000
CPA_EXPORT_ENABLED=true
CPA_PROTOCOL_ONLY=false
# OAuth grant: pkce (authorization-code, best-effort; empty SPA residual → device/browser) | device
CPA_PROTOCOL_FLOW=pkce
# PKCE fail → device flow for local disk only (product default true, matches mint.py / config.example).
# Device tokens often chat 403; entitlement_denied still hard-blocks tebi/live inject (no remint spin).
CPA_ALLOW_DEVICE_FLOW_FALLBACK=true
# free Build product gate: models-only is not enough; chat 403 = account entitlement (Manual-required)
CPA_PROBE_CHAT=true
CPA_PROBE_CHAT_REQUIRED=true
# chat gate transport: hybrid (default) | direct | cpa (cpa requires credential pin)
# CPA_PROBE_VIA=hybrid
# free Build 403 is NOT unlocked by code — do not soft-inject without chat_ok

# --- CloudMail（email_provider=cloudmail 时）---
CLOUDMAIL_URL=
CLOUDMAIL_ADMIN_EMAIL=
CLOUDMAIL_PASSWORD=

# --- Gmail app-password IMAP（email_provider=gmail；CF 域名 catch-all → Gmail）---
# 应用专用密码，不是登录密码；勿提交真实值
# EMAIL_PROVIDER=gmail
# GMAIL_IMAP_USER=you@gmail.com
# GMAIL_IMAP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_IMAP_HOST=imap.gmail.com
# GMAIL_IMAP_PORT=993
# GMAIL_IMAP_FOLDER=INBOX
# DEFAULT_DOMAINS=your-cf-domain.com

# --- grok2api ---
GROK2API_APP_KEY=
GROK2API_REMOTE_BASE=http://127.0.0.1:8000/admin/api

# --- 测试 ---
# GROK_REGISTER_LIVE=1
