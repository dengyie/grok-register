# ChatGPT provider — copy env, do not commit secrets
# Prefer project-owned nodes.json (see nodes.example.json) — no Clash required.
# CHATGPT_PROXY=http://user:pass@host:port
CHATGPT_EMAIL_SOURCE=gmail_imap
CHATGPT_OTP_TIMEOUT=180

# Self-controlled egress (preferred). When set, auto list-mode rotation —
# does NOT call Clash to select a node. Comma/newline URLs or path to .txt.
# CHATGPT_PROXY_LIST=http://user:pass@1.2.3.4:8080,http://user:pass@5.6.7.8:8080
# Or put proxies in repo-root nodes.json / REGISTER_NODES_FILE
# REGISTER_NODES_FILE=./nodes.json
# CHATGPT_PROXY_ROTATE_MODE=list
# CHATGPT_PROXY_ROTATE_EVERY=1
# CHATGPT_PROXY_ROTATE_REQUIRED=0
